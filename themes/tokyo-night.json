{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#c0caf5",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#565f89", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#7aa2f7", "bold": true },
  "h1": { "prefix": "# ", "color": "#bb9af7", "bold": true },
  "h2": { "prefix": "## ", "color": "#7dcfff", "bold": true },
  "h3": { "prefix": "### ", "color": "#bb9af7", "bold": true },
  "h4": { "prefix": "#### ", "color": "#9ece6a", "bold": true },
  "h5": { "prefix": "##### ", "color": "#e0af68", "bold": true },
  "h6": { "prefix": "###### ", "color": "#565f89", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#73daca", "italic": true },
  "strong": { "color": "#ff9e64", "bold": true },
  "hr": { "color": "#565f89", "format": "────────────────────────────" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#7dcfff", "underline": true },
  "link_text": { "color": "#bb9af7", "bold": true },
  "image": { "color": "#ad8ee6", "underline": true },
  "image_text": { "color": "#565f89", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#73daca",
    "background_color": "#16161e"
  },
  "code_block": {
    "color": "#a9b1d6",
    "margin": 0,
    "chroma": {
      "text": { "color": "#c0caf5" },
      "error": { "color": "#c0caf5" },
      "comment": { "color": "#565f89", "italic": true },
      "comment_preproc": { "color": "#ff9e64" },
      "keyword": { "color": "#bb9af7" },
      "keyword_reserved": { "color": "#bb9af7" },
      "keyword_namespace": { "color": "#bb9af7" },
      "keyword_type": { "color": "#2ac3de" },
      "keyword_constant": { "color": "#ff9e64" },
      "keyword_declaration": { "color": "#bb9af7" },
      "operator": { "color": "#89ddff" },
      "operator_word": { "color": "#bb9af7" },
      "punctuation": { "color": "#89ddff" },
      "name": { "color": "#c0caf5" },
      "name_builtin": { "color": "#f7768e" },
      "name_tag": { "color": "#f7768e" },
      "name_attribute": { "color": "#9ece6a" },
      "name_class": { "color": "#e0af68", "bold": true },
      "name_constant": { "color": "#ff9e64" },
      "name_decorator": { "color": "#7aa2f7" },
      "name_function": { "color": "#7aa2f7" },
      "name_namespace": { "color": "#7dcfff" },
      "name_variable": { "color": "#c0caf5" },
      "name_variable_instance": { "color": "#bb9af7" },
      "literal_number": { "color": "#ff9e64" },
      "literal_string": { "color": "#9ece6a" },
      "literal_string_escape": { "color": "#73daca" },
      "literal_string_interpol": { "color": "#73daca" },
      "literal_string_regex": { "color": "#b4f9f8" },
      "generic_deleted": { "color": "#f7768e" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#9ece6a" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#565f89" },
      "generic_heading": { "color": "#7aa2f7", "bold": true },
      "background": { "background_color": "#16161e" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
