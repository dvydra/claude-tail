{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#cdd6f4",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#7f849c", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#89b4fa", "bold": true },
  "h1": { "prefix": "# ", "color": "#cba6f7", "bold": true },
  "h2": { "prefix": "## ", "color": "#89dceb", "bold": true },
  "h3": { "prefix": "### ", "color": "#f5c2e7", "bold": true },
  "h4": { "prefix": "#### ", "color": "#a6e3a1", "bold": true },
  "h5": { "prefix": "##### ", "color": "#f9e2af", "bold": true },
  "h6": { "prefix": "###### ", "color": "#585b70", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#94e2d5", "italic": true },
  "strong": { "color": "#fab387", "bold": true },
  "hr": { "color": "#585b70", "format": "────────────────────────────" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#89dceb", "underline": true },
  "link_text": { "color": "#cba6f7", "bold": true },
  "image": { "color": "#f5c2e7", "underline": true },
  "image_text": { "color": "#6c7086", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#a6e3a1",
    "background_color": "#181825"
  },
  "code_block": {
    "color": "#cdd6f4",
    "margin": 0,
    "chroma": {
      "text": { "color": "#cdd6f4" },
      "error": { "color": "#cdd6f4" },
      "comment": { "color": "#7f849c", "italic": true },
      "comment_preproc": { "color": "#fab387" },
      "keyword": { "color": "#cba6f7" },
      "keyword_reserved": { "color": "#cba6f7" },
      "keyword_namespace": { "color": "#cba6f7" },
      "keyword_type": { "color": "#f9e2af" },
      "keyword_constant": { "color": "#fab387" },
      "keyword_declaration": { "color": "#cba6f7" },
      "operator": { "color": "#89dceb" },
      "operator_word": { "color": "#cba6f7" },
      "punctuation": { "color": "#94e2d5" },
      "name": { "color": "#cdd6f4" },
      "name_builtin": { "color": "#eba0ac" },
      "name_tag": { "color": "#89b4fa" },
      "name_attribute": { "color": "#f9e2af" },
      "name_class": { "color": "#f9e2af", "bold": true },
      "name_constant": { "color": "#fab387" },
      "name_decorator": { "color": "#89b4fa" },
      "name_function": { "color": "#89b4fa" },
      "name_namespace": { "color": "#f9e2af" },
      "name_variable": { "color": "#cdd6f4" },
      "name_variable_instance": { "color": "#cba6f7" },
      "literal_number": { "color": "#fab387" },
      "literal_string": { "color": "#a6e3a1" },
      "literal_string_escape": { "color": "#f5c2e7" },
      "literal_string_interpol": { "color": "#f5c2e7" },
      "literal_string_regex": { "color": "#94e2d5" },
      "generic_deleted": { "color": "#f38ba8" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#a6e3a1" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#7f849c" },
      "generic_heading": { "color": "#89b4fa", "bold": true },
      "background": { "background_color": "#181825" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
