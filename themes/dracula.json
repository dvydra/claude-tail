{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#f8f8f2",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#6272a4", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#8be9fd", "bold": true },
  "h1": { "prefix": "# ", "color": "#f1fa8c", "bold": true },
  "h2": { "prefix": "## ", "color": "#8be9fd", "bold": true },
  "h3": { "prefix": "### ", "color": "#bd93f9", "bold": true },
  "h4": { "prefix": "#### ", "color": "#50fa7b", "bold": true },
  "h5": { "prefix": "##### ", "color": "#ff79c6", "bold": true },
  "h6": { "prefix": "###### ", "color": "#6272a4", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#8be9fd", "italic": true },
  "strong": { "color": "#ffb86c", "bold": true },
  "hr": { "color": "#6272a4", "format": "────────────────────────────" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#8be9fd", "underline": true },
  "link_text": { "color": "#bd93f9", "bold": true },
  "image": { "color": "#ff79c6", "underline": true },
  "image_text": { "color": "#6272a4", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#50fa7b",
    "background_color": "#21222c"
  },
  "code_block": {
    "color": "#f8f8f2",
    "margin": 0,
    "chroma": {
      "text": { "color": "#f8f8f2" },
      "error": { "color": "#f8f8f2" },
      "comment": { "color": "#6272a4", "italic": true },
      "comment_preproc": { "color": "#ff79c6" },
      "keyword": { "color": "#ff79c6" },
      "keyword_reserved": { "color": "#ff79c6" },
      "keyword_namespace": { "color": "#ff79c6" },
      "keyword_type": { "color": "#8be9fd" },
      "keyword_constant": { "color": "#bd93f9" },
      "keyword_declaration": { "color": "#8be9fd", "italic": true },
      "operator": { "color": "#ff79c6" },
      "operator_word": { "color": "#ff79c6" },
      "punctuation": { "color": "#f8f8f2" },
      "name": { "color": "#f8f8f2" },
      "name_builtin": { "color": "#8be9fd", "italic": true },
      "name_tag": { "color": "#ff79c6" },
      "name_attribute": { "color": "#50fa7b" },
      "name_class": { "color": "#50fa7b" },
      "name_constant": { "color": "#bd93f9" },
      "name_decorator": { "color": "#50fa7b" },
      "name_function": { "color": "#50fa7b" },
      "name_namespace": { "color": "#f8f8f2" },
      "name_variable": { "color": "#f8f8f2" },
      "name_variable_instance": { "color": "#bd93f9", "italic": true },
      "literal_number": { "color": "#bd93f9" },
      "literal_string": { "color": "#f1fa8c" },
      "literal_string_escape": { "color": "#ff79c6" },
      "literal_string_interpol": { "color": "#ff79c6" },
      "literal_string_regex": { "color": "#ff5555" },
      "generic_deleted": { "color": "#ff5555" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#50fa7b" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#6272a4" },
      "generic_heading": { "color": "#bd93f9", "bold": true },
      "background": { "background_color": "#282a36" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
