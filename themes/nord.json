{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#d8dee9",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#616e88", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#88c0d0", "bold": true },
  "h1": { "prefix": "# ", "color": "#8fbcbb", "bold": true },
  "h2": { "prefix": "## ", "color": "#81a1c1", "bold": true },
  "h3": { "prefix": "### ", "color": "#b48ead", "bold": true },
  "h4": { "prefix": "#### ", "color": "#a3be8c", "bold": true },
  "h5": { "prefix": "##### ", "color": "#ebcb8b", "bold": true },
  "h6": { "prefix": "###### ", "color": "#4c566a", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#8fbcbb", "italic": true },
  "strong": { "color": "#d08770", "bold": true },
  "hr": { "color": "#4c566a", "format": "────────────────────────────" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#88c0d0", "underline": true },
  "link_text": { "color": "#81a1c1", "bold": true },
  "image": { "color": "#b48ead", "underline": true },
  "image_text": { "color": "#4c566a", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#a3be8c",
    "background_color": "#3b4252"
  },
  "code_block": {
    "color": "#d8dee9",
    "margin": 0,
    "chroma": {
      "text": { "color": "#d8dee9" },
      "error": { "color": "#d8dee9" },
      "comment": { "color": "#4c566a", "italic": true },
      "comment_preproc": { "color": "#5e81ac" },
      "keyword": { "color": "#81a1c1" },
      "keyword_reserved": { "color": "#81a1c1" },
      "keyword_namespace": { "color": "#81a1c1" },
      "keyword_type": { "color": "#8fbcbb" },
      "keyword_constant": { "color": "#5e81ac" },
      "keyword_declaration": { "color": "#81a1c1" },
      "operator": { "color": "#81a1c1" },
      "operator_word": { "color": "#81a1c1" },
      "punctuation": { "color": "#eceff4" },
      "name": { "color": "#d8dee9" },
      "name_builtin": { "color": "#8fbcbb" },
      "name_tag": { "color": "#81a1c1" },
      "name_attribute": { "color": "#8fbcbb" },
      "name_class": { "color": "#8fbcbb" },
      "name_constant": { "color": "#d8dee9" },
      "name_decorator": { "color": "#d08770" },
      "name_function": { "color": "#88c0d0" },
      "name_namespace": { "color": "#8fbcbb" },
      "name_variable": { "color": "#d8dee9" },
      "name_variable_instance": { "color": "#d8dee9" },
      "literal_number": { "color": "#b48ead" },
      "literal_string": { "color": "#a3be8c" },
      "literal_string_escape": { "color": "#ebcb8b" },
      "literal_string_interpol": { "color": "#ebcb8b" },
      "literal_string_regex": { "color": "#ebcb8b" },
      "generic_deleted": { "color": "#bf616a" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#a3be8c" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#4c566a" },
      "generic_heading": { "color": "#88c0d0", "bold": true },
      "background": { "background_color": "#2e3440" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
