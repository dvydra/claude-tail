{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#abb2bf",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#5c6370", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#61afef", "bold": true },
  "h1": { "prefix": "# ", "color": "#e5c07b", "bold": true },
  "h2": { "prefix": "## ", "color": "#56b6c2", "bold": true },
  "h3": { "prefix": "### ", "color": "#c678dd", "bold": true },
  "h4": { "prefix": "#### ", "color": "#98c379", "bold": true },
  "h5": { "prefix": "##### ", "color": "#e06c75", "bold": true },
  "h6": { "prefix": "###### ", "color": "#5c6370", "bold": true },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#56b6c2", "italic": true },
  "strong": { "color": "#d19a66", "bold": true },
  "hr": { "color": "#5c6370", "format": "────────────────────────────" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". " },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#56b6c2", "underline": true },
  "link_text": { "color": "#61afef", "bold": true },
  "image": { "color": "#c678dd", "underline": true },
  "image_text": { "color": "#5c6370", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#98c379",
    "background_color": "#21252b"
  },
  "code_block": {
    "color": "#abb2bf",
    "margin": 0,
    "chroma": {
      "text": { "color": "#abb2bf" },
      "error": { "color": "#abb2bf" },
      "comment": { "color": "#5c6370", "italic": true },
      "comment_preproc": { "color": "#c678dd" },
      "keyword": { "color": "#c678dd" },
      "keyword_reserved": { "color": "#c678dd" },
      "keyword_namespace": { "color": "#c678dd" },
      "keyword_type": { "color": "#e5c07b" },
      "keyword_constant": { "color": "#d19a66" },
      "keyword_declaration": { "color": "#c678dd" },
      "operator": { "color": "#56b6c2" },
      "operator_word": { "color": "#c678dd" },
      "punctuation": { "color": "#abb2bf" },
      "name": { "color": "#abb2bf" },
      "name_builtin": { "color": "#e06c75" },
      "name_tag": { "color": "#e06c75" },
      "name_attribute": { "color": "#d19a66" },
      "name_class": { "color": "#e5c07b", "bold": true },
      "name_constant": { "color": "#d19a66" },
      "name_decorator": { "color": "#61afef" },
      "name_function": { "color": "#61afef" },
      "name_namespace": { "color": "#e5c07b" },
      "name_variable": { "color": "#e06c75" },
      "name_variable_instance": { "color": "#e06c75" },
      "literal_number": { "color": "#d19a66" },
      "literal_string": { "color": "#98c379" },
      "literal_string_escape": { "color": "#56b6c2" },
      "literal_string_interpol": { "color": "#56b6c2" },
      "literal_string_regex": { "color": "#98c379" },
      "generic_deleted": { "color": "#e06c75" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#98c379" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#5c6370" },
      "generic_heading": { "color": "#61afef", "bold": true },
      "background": { "background_color": "#21252b" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
