{
  "document": {
    "block_prefix": "\n",
    "block_suffix": "\n",
    "color": "#f7f0ff",
    "margin": 0
  },
  "block_quote": { "indent": 1, "indent_token": "│ ", "color": "#b14bff", "italic": true },
  "paragraph": {},
  "list": { "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#00eaff", "bold": true },
  "h1": { "prefix": "# ", "color": "#ff2e97", "bold": true },
  "h2": { "prefix": "## ", "color": "#00eaff", "bold": true },
  "h3": { "prefix": "### ", "color": "#b14bff", "bold": true },
  "h4": { "prefix": "#### ", "color": "#aaff00", "bold": true },
  "h5": { "prefix": "##### ", "color": "#ffe600" },
  "h6": { "prefix": "###### ", "color": "#7a5fae" },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#5ef1ff", "italic": true },
  "strong": { "color": "#ffe600", "bold": true },
  "hr": { "color": "#ff2e97", "format": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━" },
  "item": { "block_prefix": "• ", "color": "#ff6ac1" },
  "enumeration": { "block_prefix": ". ", "color": "#5ef1ff" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#00eaff", "underline": true },
  "link_text": { "color": "#ff2e97", "bold": true },
  "image": { "color": "#b14bff", "underline": true },
  "image_text": { "color": "#7a5fae", "format": "Image: {{.text}} →" },
  "code": {
    "prefix": "",
    "suffix": "",
    "color": "#aaff00",
    "background_color": "#2a1a4a"
  },
  "code_block": {
    "color": "#f7f0ff",
    "margin": 0,
    "chroma": {
      "text": { "color": "#f7f0ff" },
      "error": { "color": "#f7f0ff" },
      "comment": { "color": "#7a5fae", "italic": true },
      "comment_preproc": { "color": "#ff6b00" },
      "keyword": { "color": "#ff2e97" },
      "keyword_reserved": { "color": "#ff2e97" },
      "keyword_namespace": { "color": "#ff2e97" },
      "keyword_type": { "color": "#00eaff" },
      "keyword_constant": { "color": "#ff6b00" },
      "keyword_declaration": { "color": "#ff2e97" },
      "operator": { "color": "#5ef1ff" },
      "operator_word": { "color": "#ff2e97" },
      "punctuation": { "color": "#5ef1ff" },
      "name": { "color": "#f7f0ff" },
      "name_builtin": { "color": "#ff003c" },
      "name_tag": { "color": "#ff003c" },
      "name_attribute": { "color": "#aaff00" },
      "name_class": { "color": "#ffe600", "bold": true },
      "name_constant": { "color": "#ff6b00" },
      "name_decorator": { "color": "#00eaff" },
      "name_function": { "color": "#00eaff" },
      "name_namespace": { "color": "#5ef1ff" },
      "name_variable": { "color": "#f7f0ff" },
      "name_variable_instance": { "color": "#ff2e97" },
      "literal_number": { "color": "#ff6b00" },
      "literal_string": { "color": "#aaff00" },
      "literal_string_escape": { "color": "#39ff14" },
      "literal_string_interpol": { "color": "#39ff14" },
      "literal_string_regex": { "color": "#5ef1ff" },
      "generic_deleted": { "color": "#ff003c" },
      "generic_emph": { "italic": true },
      "generic_inserted": { "color": "#aaff00" },
      "generic_strong": { "bold": true },
      "generic_subheading": { "color": "#7a5fae" },
      "generic_heading": { "color": "#ff2e97", "bold": true },
      "background": { "background_color": "#1a0a2e" }
    }
  },
  "table": { "center_separator": "┼", "column_separator": "│", "row_separator": "─" },
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
